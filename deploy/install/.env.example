# dreamreader-sync deploy config. Copy to `.env` and edit, or run
# `./scripts/install.sh` to generate it interactively.

# Build proxies (China-friendly Go proxy; leave HTTP(S)_PROXY empty unless needed).
HERTZ_GOPROXY=https://goproxy.cn,direct
HERTZ_BUILD_NETWORK=host

# Public domain the sync API is served on (host only, no scheme). Used to render
# the Nginx site. e.g. api.mr.64hz.cn
DREAMSYNC_PUBLIC_DOMAIN=sync.example.com

# Host port the service binds on (127.0.0.1:PORT). Nginx proxies to it.
DREAMSYNC_HTTP_PORT=8090

# IAM integration. Issuer = the public IAM base URL (token issuer + audience
# check). JWKS is derived as {issuer}/realms/user/jwks unless set explicitly.
DREAMSYNC_IAM_ISSUER=https://account.example.com
DREAMSYNC_JWKS_URI=
DREAMSYNC_CLIENT_ID=dream_manga_reader

# Per-document upload cap (bytes; 8 MiB default). CORS is for a web build only.
DREAMSYNC_MAX_DOC_BYTES=8388608
DREAMSYNC_CORS_ORIGINS=

# Set to y (and layer docker-compose.iam-network.yml) to reach IAM by internal
# service name on its Docker network instead of the public internet.
DREAMSYNC_USE_IAM_NET=n
HERTZ_IAM_NETWORK=hertz-iam_default
